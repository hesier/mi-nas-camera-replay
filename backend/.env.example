# 多通道视频目录（必填，数字从 1 开始）
VIDEO_ROOT_1=./videos/cam1

# 应用访问密码（必填）
APP_PASSWORD=change-me

# 注意：当前版本不再支持仅配置旧的 VIDEO_ROOT（必须使用 VIDEO_ROOT_数字）
# VIDEO_ROOT=/Volumes/share-1/XiaomiCamera_00_B88880974F01
INDEX_ON_STARTUP=false
INDEX_SCHEDULER_ENABLED=false
INDEX_SCHEDULER_TIME=03:00
SQLITE_URL=sqlite:///./replay.db
TIMEZONE=Asia/Shanghai
